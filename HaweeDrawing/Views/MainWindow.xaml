<Window x:Class="HaweeDrawing.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:HaweeDrawing.Converters"
    Title="Revit Pipe Exporter" 
    Height="600" 
    Width="1000"
    WindowStartupLocation="CenterScreen"
    ResizeMode="CanResize">
<Window.Resources>
    <converters:InverseBooleanConverter x:Key="InverseBooleanConverter"/>
    <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        
    <Style TargetType="Button">
        <Setter Property="Padding" Value="10,5"/>
        <Setter Property="Margin" Value="5"/>
        <Setter Property="MinWidth" Value="100"/>
    </Style>
        <Style TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="5"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Padding" Value="5"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Padding" Value="5"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Margin" Value="5"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Filter Section -->
        <GroupBox Grid.Row="0" Header="Filters" Padding="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="System:" FontWeight="Bold"/>
                <ComboBox Grid.Row="0" Grid.Column="1"
                          ItemsSource="{Binding SystemNames}"
                          SelectedItem="{Binding SelectedSystemName}"
                          IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBooleanConverter}}"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Level:" FontWeight="Bold"/>
                <ComboBox Grid.Row="1" Grid.Column="1"
                          ItemsSource="{Binding LevelNames}"
                          SelectedItem="{Binding SelectedLevelName}"
                          IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBooleanConverter}}"/>

                <CheckBox Grid.Row="2" Grid.Column="1"
                          Content="Filter by Active View"
                          IsChecked="{Binding FilterByActiveView}"
                          IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBooleanConverter}}"/>
            </Grid>
        </GroupBox>

        <!-- Statistics -->
        <Border Grid.Row="1" Background="#F0F0F0" Padding="10" Margin="0,5">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Total Pipes: " FontWeight="Bold"/>
                <TextBlock Text="{Binding TotalPipes}" FontWeight="Bold" Foreground="Blue"/>
            </StackPanel>
        </Border>

        <!-- Loading Indicator -->
        <Border Grid.Row="2" Background="#FFF9E6" Padding="10" Margin="0,5"
                Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="? Loading..." FontWeight="Bold" Foreground="#FF6600"/>
            </StackPanel>
        </Border>

        <!-- Data Grid -->
        <GroupBox Grid.Row="3" Header="Pipes" Margin="0,5">
            <DataGrid ItemsSource="{Binding Pipes}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      SelectionMode="Extended"
                      AlternatingRowBackground="#F5F5F5">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="80"/>
                    <DataGridTextColumn Header="Level" Binding="{Binding LevelName}" Width="120"/>
                    <DataGridTextColumn Header="System Type" Binding="{Binding SystemTypeName}" Width="180"/>
                    <DataGridTextColumn Header="Pipe Type" Binding="{Binding PipeTypeName}" Width="150"/>
                    <DataGridTextColumn Header="Diameter (m)" Binding="{Binding Diameter, StringFormat={}{0:F4}}" Width="100"/>
                    <DataGridTextColumn Header="Start Point" Binding="{Binding StartPoint}" Width="180"/>
                    <DataGridTextColumn Header="End Point" Binding="{Binding EndPoint}" Width="180"/>
                    <DataGridTextColumn Header="Connectors" Binding="{Binding Connectors.Count}" Width="90"/>
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>

        <!-- Export Section -->
        <GroupBox Grid.Row="4" Header="Export" Padding="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Export Path:" FontWeight="Bold"/>
                <TextBox Grid.Row="0" Grid.Column="1"
                         Text="{Binding ExportFilePath, UpdateSourceTrigger=PropertyChanged}"
                         IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBooleanConverter}}"/>
                <Button Grid.Row="0" Grid.Column="2"
                        Content="Browse..."
                        Command="{Binding BrowseCommand}"/>

                <Button Grid.Row="1" Grid.Column="2"
                        Content="Export to JSON"
                        Command="{Binding ExportCommand}"
                        Background="#4CAF50"
                        Foreground="White"
                        FontWeight="Bold"/>
            </Grid>
        </GroupBox>
    </Grid>
</Window>
